<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bagphat Football Academy</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --green: #16a34a;
    --dark-green: #064e20;
    --light-green: #22c55e;
    --black: #050a05;
    --dark: #0d1a0d;
    --card: #111a11;
    --white: #f0fff0;
    --gray: #8aaa8a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Rajdhani', sans-serif; background: var(--black); color: var(--white); overflow-x: hidden; }

  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--black); }
  ::-webkit-scrollbar-thumb { background: var(--green); }

  /* NAV */
  nav {
    position: fixed; top: 0; width: 100%; z-index: 999;
    background: rgba(5,10,5,0.97); backdrop-filter: blur(20px);
    padding: 0 50px; height: 68px;
    display: flex; justify-content: space-between; align-items: center;
    border-bottom: 1px solid rgba(22,163,74,0.3);
  }
  .nav-logo { font-family: 'Bebas Neue', sans-serif; font-size: 26px; color: var(--white); letter-spacing: 3px; display: flex; align-items: center; gap: 10px; }
  .nav-logo span { color: var(--light-green); }
  .nav-ball { font-size: 22px; animation: spin 4s linear infinite; display: inline-block; }
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .nav-links { display: flex; gap: 35px; list-style: none; }
  .nav-links a { color: var(--gray); text-decoration: none; font-size: 15px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; transition: color 0.3s; position: relative; }
  .nav-links a::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 2px; background: var(--light-green); transition: width 0.3s; }
  .nav-links a:hover { color: var(--white); }
  .nav-links a:hover::after { width: 100%; }
  .nav-cta { background: var(--green); color: var(--white); padding: 10px 24px; font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 14px; letter-spacing: 2px; text-transform: uppercase; border: none; cursor: pointer; text-decoration: none; transition: background 0.3s; clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%); }
  .nav-cta:hover { background: var(--light-green); }

  /* MARQUEE */
  .marquee-bar { background: var(--green); padding: 9px 0; overflow: hidden; margin-top: 68px; }
  .marquee-inner { display: flex; animation: slide 25s linear infinite; }
  .marquee-item { font-family: 'Bebas Neue', sans-serif; font-size: 13px; letter-spacing: 4px; color: rgba(255,255,255,0.9); white-space: nowrap; padding: 0 30px; }
  .marquee-sep { color: rgba(255,255,255,0.4); padding: 0 5px; line-height: 1.2; }
  @keyframes slide { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* HERO */
  .hero { min-height: 100vh; display: flex; align-items: center; position: relative; overflow: hidden; background: radial-gradient(ellipse at 30% 50%, rgba(22,163,74,0.15) 0%, transparent 60%), var(--black); padding: 0 50px; }
  .hero-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(22,163,74,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(22,163,74,0.05) 1px, transparent 1px); background-size: 60px 60px; }
  .hero-content { position: relative; z-index: 2; max-width: 700px; }
  .hero-tag { display: inline-flex; align-items: center; gap: 8px; background: rgba(22,163,74,0.15); border: 1px solid rgba(22,163,74,0.4); padding: 6px 16px; margin-bottom: 28px; font-size: 12px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--light-green); }
  .hero h1 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(70px, 11vw, 130px); line-height: 0.88; letter-spacing: 2px; margin-bottom: 24px; }
  .hero h1 .line2 { color: var(--light-green); }
  .hero h1 .line3 { color: transparent; -webkit-text-stroke: 1px rgba(255,255,255,0.25); }
  .hero-desc { font-size: 18px; color: var(--gray); line-height: 1.7; max-width: 480px; margin-bottom: 40px; }
  .hero-stats { display: flex; gap: 40px; margin-bottom: 44px; flex-wrap: wrap; }
  .stat-item { position: relative; padding-right: 20px; }
  .stat-item::after { content: ''; position: absolute; right: 0; top: 10%; height: 80%; width: 1px; background: rgba(22,163,74,0.3); }
  .stat-item:last-child::after { display: none; }
  .stat-num { font-family: 'Bebas Neue', sans-serif; font-size: 46px; color: var(--light-green); line-height: 1; }
  .stat-label { font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--gray); margin-top: 2px; }
  .hero-btns { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-main { background: var(--green); color: var(--white); padding: 15px 36px; font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 15px; letter-spacing: 2px; text-transform: uppercase; border: none; cursor: pointer; text-decoration: none; display: inline-block; clip-path: polygon(10px 0%, 100% 0%, calc(100% - 10px) 100%, 0% 100%); transition: background 0.3s, transform 0.2s; }
  .btn-main:hover { background: var(--light-green); transform: translateY(-2px); }
  .btn-ghost { background: transparent; color: var(--white); padding: 14px 36px; font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 15px; letter-spacing: 2px; text-transform: uppercase; cursor: pointer; text-decoration: none; display: inline-block; border: 1px solid rgba(255,255,255,0.2); transition: border-color 0.3s, color 0.3s; }
  .btn-ghost:hover { border-color: var(--light-green); color: var(--light-green); }
  .hero-ball-bg { position: absolute; right: -80px; top: 50%; transform: translateY(-50%); font-size: 500px; opacity: 0.04; animation: floatBall 8s ease-in-out infinite; line-height: 1; }
  @keyframes floatBall { 0%, 100% { transform: translateY(-50%) rotate(0deg); } 50% { transform: translateY(-54%) rotate(15deg); } }

  /* SECTION */
  section { padding: 100px 50px; }
  .section-tag { font-size: 11px; font-weight: 700; letter-spacing: 4px; text-transform: uppercase; color: var(--light-green); display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
  .section-tag::before { content: ''; width: 30px; height: 2px; background: var(--green); }
  .section-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(42px, 6vw, 72px); letter-spacing: 2px; line-height: 1; }
  .section-sub { color: var(--gray); font-size: 17px; line-height: 1.7; margin-top: 14px; max-width: 550px; }

  /* PROGRAMS */
  #programs { background: var(--dark); }
  .programs-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 60px; flex-wrap: wrap; gap: 20px; }
  .programs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }
  .prog-card { background: var(--card); padding: 36px 30px; border: 1px solid rgba(22,163,74,0.1); position: relative; overflow: hidden; transition: border-color 0.3s, transform 0.3s; }
  .prog-card::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 3px; background: var(--green); transform: scaleX(0); transform-origin: left; transition: transform 0.4s; }
  .prog-card:hover { border-color: rgba(22,163,74,0.4); transform: translateY(-4px); }
  .prog-card:hover::before { transform: scaleX(1); }
  .prog-number { font-family: 'Bebas Neue', sans-serif; font-size: 64px; color: rgba(22,163,74,0.08); line-height: 1; position: absolute; top: 20px; right: 24px; }
  .prog-age { font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--light-green); margin-bottom: 12px; }
  .prog-name { font-family: 'Bebas Neue', sans-serif; font-size: 26px; letter-spacing: 1px; margin-bottom: 14px; }
  .prog-desc { font-size: 15px; color: var(--gray); line-height: 1.7; }

  /* ABOUT */
  #about { background: var(--black); }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; max-width: 1200px; margin: 0 auto; }
  .about-visual { background: var(--dark); border: 1px solid rgba(22,163,74,0.2); padding: 60px 50px; position: relative; overflow: hidden; }
  .about-visual::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 50%, rgba(22,163,74,0.1) 0%, transparent 70%); }
  .about-big-text { font-family: 'Bebas Neue', sans-serif; font-size: 90px; line-height: 0.85; letter-spacing: 2px; color: var(--light-green); position: relative; z-index: 1; }
  .about-big-sub { font-size: 16px; color: var(--gray); margin-top: 20px; position: relative; z-index: 1; line-height: 1.6; }
  .about-ball-deco { position: absolute; bottom: -30px; right: -30px; font-size: 180px; opacity: 0.06; }
  .about-p { color: var(--gray); font-size: 17px; line-height: 1.8; margin-top: 20px; }
  .pillars-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 36px; }
  .pillar { background: var(--card); padding: 22px 20px; border: 1px solid rgba(22,163,74,0.15); border-left: 3px solid var(--green); transition: border-color 0.3s; }
  .pillar:hover { border-color: var(--light-green); }
  .pillar-icon { font-size: 22px; margin-bottom: 8px; }
  .pillar-name { font-weight: 700; font-size: 15px; letter-spacing: 1px; text-transform: uppercase; }
  .pillar-desc { font-size: 13px; color: var(--gray); margin-top: 4px; line-height: 1.5; }

  /* COACHES */
  #coaches { background: var(--dark); }
  .coaches-header { text-align: center; margin-bottom: 60px; }
  .coaches-header .section-tag { justify-content: center; }
  .coaches-header .section-tag::before { display: none; }
  .coaches-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; max-width: 1100px; margin: 0 auto; }
  .coach-card { background: var(--card); border: 1px solid rgba(22,163,74,0.15); overflow: hidden; transition: transform 0.3s, border-color 0.3s; }
  .coach-card:hover { transform: translateY(-8px); border-color: rgba(22,163,74,0.5); }
  .coach-top { background: linear-gradient(135deg, var(--dark-green), rgba(22,163,74,0.6)); padding: 40px 30px 30px; text-align: center; }
  .coach-emoji { width: 76px; height: 76px; background: rgba(0,0,0,0.3); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 34px; margin: 0 auto 16px; border: 2px solid rgba(255,255,255,0.2); }
  .coach-name { font-family: 'Bebas Neue', sans-serif; font-size: 26px; letter-spacing: 1px; }
  .coach-role { color: rgba(255,255,255,0.7); font-size: 13px; letter-spacing: 2px; text-transform: uppercase; font-weight: 600; margin-top: 4px; }
  .coach-body { padding: 24px 28px; }
  .coach-bio { font-size: 15px; color: var(--gray); line-height: 1.7; }
  .coach-tag { display: inline-block; background: rgba(22,163,74,0.15); border: 1px solid rgba(22,163,74,0.3); color: var(--light-green); font-size: 11px; letter-spacing: 2px; text-transform: uppercase; font-weight: 700; padding: 4px 12px; margin-top: 16px; }

  /* ENROLL */
  #enroll { background: var(--black); position: relative; overflow: hidden; }
  #enroll::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 0%, rgba(22,163,74,0.12) 0%, transparent 60%); }
  .enroll-inner { max-width: 700px; margin: 0 auto; text-align: center; position: relative; z-index: 1; }
  .enroll-inner .section-tag { justify-content: center; }
  .enroll-inner .section-tag::before { display: none; }
  .enroll-inner .section-title { font-size: clamp(50px, 8vw, 90px); }
  .enroll-inner .section-sub { margin: 16px auto 48px; }
  .form-wrap { display: flex; flex-direction: column; gap: 14px; max-width: 480px; margin: 0 auto; }
  .form-row { display: flex; gap: 14px; }
  .form-input { flex: 1; padding: 16px 20px; background: rgba(255,255,255,0.04); border: 1px solid rgba(22,163,74,0.25); color: var(--white); font-family: 'Rajdhani', sans-serif; font-size: 16px; outline: none; transition: border-color 0.3s; }
  .form-input::placeholder { color: rgba(255,255,255,0.3); }
  .form-input:focus { border-color: var(--light-green); }
  .form-btn { width: 100%; padding: 18px; background: var(--green); color: var(--white); font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 16px; letter-spacing: 3px; text-transform: uppercase; border: none; cursor: pointer; transition: background 0.3s; clip-path: polygon(12px 0%, 100% 0%, calc(100% - 12px) 100%, 0% 100%); }
  .form-btn:hover { background: var(--light-green); }
  .phone-line { margin-top: 24px; font-size: 15px; color: var(--gray); }
  .phone-line strong { color: var(--light-green); font-size: 18px; }

  /* FOOTER */
  footer { background: var(--dark); padding: 50px; border-top: 1px solid rgba(22,163,74,0.2); }
  .footer-inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 30px; }
  .footer-logo { font-family: 'Bebas Neue', sans-serif; font-size: 30px; letter-spacing: 3px; }
  .footer-logo span { color: var(--light-green); }
  .footer-links { display: flex; gap: 30px; flex-wrap: wrap; }
  .footer-links a { color: var(--gray); text-decoration: none; font-size: 14px; letter-spacing: 1px; text-transform: uppercase; font-weight: 600; transition: color 0.3s; }
  .footer-links a:hover { color: var(--light-green); }
  .footer-copy { width: 100%; text-align: center; color: rgba(255,255,255,0.2); font-size: 13px; margin-top: 30px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 24px; }

  @media (max-width: 900px) {
    nav { padding: 0 20px; }
    .nav-links, .nav-cta { display: none; }
    section { padding: 70px 20px; }
    .hero { padding: 0 20px; }
    .programs-grid { grid-template-columns: 1fr; }
    .about-grid { grid-template-columns: 1fr; gap: 40px; }
    .coaches-grid { grid-template-columns: 1fr; }
    .footer-inner { flex-direction: column; text-align: center; }
    .form-row { flex-direction: column; }
  }
</style>
</head>
